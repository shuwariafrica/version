#compdef version
# zsh completion for the `version` CLI
#
# Install:
#   cp _version "${fpath[1]}/"      # system site-functions
#   # or, for a single user, place in any dir on your $fpath and run
#   autoload -Uz compinit && compinit

_version() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a globals
    globals=(
        '(-r --repository)'{-r,--repository}'[repository directory]:path:_files -/'
        '(-b --basis-commit)'{-b,--basis-commit}'[commit-ish to resolve against]:rev:'
        '--pr[pull request number]:number:'
        '--branch-override[override branch name]:branch:'
        '--sha-length[SHA length for the full renderer (7..64)]:length:'
        '(-v --verbose)'{-v,--verbose}'[enable verbose diagnostics]'
        '--ci[CI mode (compact console, no colours)]'
        '(--no-colour --no-color)'{--no-colour,--no-color}'[disable ANSI colours]'
        '*'{-e,--emit}'[add output sink]:sink:(console raw json)'
        '--console-style[console rendering style]:style:(pretty compact)'
        '--help[print help]'
        '--version[print version]'
    )

    _arguments -s -C $globals \
        '1: :->command' \
        '*:: :->args'

    case $state in
        command)
            local -a commands
            commands=(
                'target:Show the resolution target, or record a target directive'
                'tag:Create an annotated tag at HEAD'
                'list:List the release history'
            )
            _describe -t commands 'command' commands
            ;;
        args)
            case $line[1] in
                target)
                    _arguments -s $globals \
                        '(-s --set)'{-s,--set}'[record target: <version>]:version:' \
                        '(-i --increment)'{-i,--increment}'[record version: <keyword>]:keyword:(breaking feat feature fix major minor patch)' \
                        '--dry-run[preview without committing]' \
                        '--no-sign[create the commit unsigned]'
                    ;;
                tag)
                    _arguments -s $globals \
                        '(-m --message)'{-m,--message}'[tag message]:message:' \
                        '--no-sign[create the tag unsigned]' \
                        '--dry-run[preview without tagging]' \
                        '1::version:'
                    ;;
                list)
                    _arguments -s $globals \
                        '(-n --limit)'{-n,--limit}'[limit to the newest N entries]:count:' \
                        '--final[exclude pre-releases]' \
                        '--since[releases at or above VERSION]:version:' \
                        '--until[releases at or below VERSION]:version:' \
                        '--details[show the tag and source-commit date]'
                    ;;
            esac
            ;;
    esac
}

_version "$@"
