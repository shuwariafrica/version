# Core resolution: fallback, concrete, dirty, snapshot, pre-release

# No git repo - fallback to 0.1.0-SNAPSHOT
> checkFallback

# Initialise repo
> gitInit
> reload

# Snapshot with metadata (no tags yet)
> checkMetadata

# Mode 1: clean tag = concrete version
> gitTag
> reload
> checkConcreteTag

# Mode 2: dirty worktree at tag = snapshot with dirty marker
> dirty
> reload
> checkDirtyTag

# Mode 2: after commit = snapshot with commit count and SHA
> gitCommit
> reload
> checkAfterCommit

# Mode 1: pre-release tag = concrete pre-release
> gitTagPreRelease
> reload
> checkPreRelease
