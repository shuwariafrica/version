# Commit directive resolution

> gitInit
> reload

# Default: patch bump after final tag
> gitCommitMsg housekeeping
> reload
> checkPrefix 1.0.1-SNAPSHOT

# version: minor
> gitCommitMsg version: minor
> reload
> checkPrefix 1.1.0-SNAPSHOT

# version: major
> gitCommitMsg version: major
> reload
> checkPrefix 2.0.0-SNAPSHOT

# target: directive
> gitCommitMsg target: 3.0.0
> reload
> checkPrefix 3.0.0-SNAPSHOT

# Standalone shorthand: breaking:
> gitTag v3.0.0
> gitCommitMsg breaking: API overhaul
> reload
> checkPrefix 4.0.0-SNAPSHOT

# Standalone shorthand: feat:
> gitTag v4.0.0
> gitCommitMsg feat: Add new feature
> reload
> checkPrefix 4.1.0-SNAPSHOT

# versionHistory holds every annotated version tag, v-prefix stripped
> reload
> checkHistory 1.0.0 3.0.0 4.0.0
